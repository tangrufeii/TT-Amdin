<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.tt</groupId>
        <artifactId>tt-admin-backend</artifactId>
        <version>1.0.0</version>
    </parent>

    <artifactId>tt-admin-plugins</artifactId>
    <packaging>pom</packaging>
    <modules>
        <module>tt-admin-demo</module>
        <module>tt-admin-backup</module>
        <module>tt-admin-monitor</module>
        <module>tt-admin-codegen</module>
        <module>tt-admin-ai-chat</module>
        <module>tt-admin-test</module>
        <module>tt-admin-iframe-vue</module>
        <module>tt-admin-iframe-react</module>
        <module>tt-admin-wc-vue</module>
        <module>tt-admin-wc-react</module>
        <module>tt-admin-webide</module>
    </modules>
    <dependencies>
        <dependency>
            <groupId>io.swagger.core.v3</groupId>
            <artifactId>swagger-annotations-jakarta</artifactId>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>
    </dependencies>
    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <plugin.copyDependencies.excludeScope>provided</plugin.copyDependencies.excludeScope>
        <plugin.copyDependencies.excludeGroupIds>org.junit,org.mockito,org.assertj,org.hamcrest,org.skyscreamer,org.xmlunit,org.awaitility,io.rest-assured,net.bytebuddy,org.apiguardian,org.opentest4j,org.objenesis,org.hdrhistogram,org.latencyutils,com.jayway.jsonpath,net.minidev,org.springframework.boot,org.slf4j,ch.qos.logback,org.apache.logging.log4j,io.micrometer,io.projectreactor,org.reactivestreams</plugin.copyDependencies.excludeGroupIds>
        <plugin.copyDependencies.excludeArtifactIds>spring-boot-starter-test,spring-boot-test,spring-boot-test-autoconfigure,spring-test,junit-jupiter,junit-jupiter-api,junit-jupiter-engine,junit-jupiter-params,junit-platform-commons,junit-platform-engine,mockito-core,mockito-junit-jupiter,assertj-core,awaitility,hamcrest,jsonassert,json-path,rest-assured-common,apiguardian-api,opentest4j,byte-buddy,byte-buddy-agent,objenesis,HdrHistogram,LatencyUtils,xmlunit-core</plugin.copyDependencies.excludeArtifactIds>
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>3.1.0</version>
                <executions>
                    <execution>
                        <id>clean-plugin-lib</id>
                        <phase>process-sources</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <delete dir="${project.build.directory}/lib" />
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>3.6.1</version>
                <executions>
                    <execution>
                        <id>copy-plugin-dependencies</id>
                        <phase>process-sources</phase>
                        <goals>
                            <goal>copy-dependencies</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/lib</outputDirectory>
                            <excludeScope>${plugin.copyDependencies.excludeScope}</excludeScope>
                            <excludeGroupIds>${plugin.copyDependencies.excludeGroupIds}</excludeGroupIds>
                            <excludeArtifactIds>${plugin.copyDependencies.excludeArtifactIds}</excludeArtifactIds>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
